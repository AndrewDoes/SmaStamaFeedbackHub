# --- DATABASE CONFIG ---
# The name of the database container (usually 'db')
POSTGRES_DB=smastama
POSTGRES_USER=postgres
POSTGRES_PASSWORD=smastama_dev_db_pass

# --- AZURE STORAGE (FOR ATTACHMENTS) ---
# Replace with the real connection string from the school's Azure Portal
AZURE_BLOB_STORAGE_URL=DefaultEndpointsProtocol=https;AccountName=...;AccountKey=...;EndpointSuffix=core.windows.net

# --- SECURITY ---
# Replace with a very long random string for production
JWT_KEY=SecretKeyMustBeVeryLongToBeSecure123!_Production_Value
