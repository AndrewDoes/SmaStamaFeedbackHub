# --- DATABASE CONFIG ---
POSTGRES_DB=smastama
POSTGRES_USER=postgres
POSTGRES_PASSWORD=generate_a_strong_password_here

# --- BACKEND AUTH CONFIG ---
# Use a long random string for JWT_KEY (min 32 chars)
JWT_KEY=generate_a_very_long_secret_key_for_production_123!
JWT_ISSUER=https://yourdomain.com
JWT_AUDIENCE=https://yourdomain.com
ASPNETCORE_ENVIRONMENT=Production

# --- STORAGE CONFIG ---
# Azure Blob Storage Connection String
AZURE_BLOB_STORAGE_URL=DefaultEndpointsProtocol=https;AccountName=...;AccountKey=...;EndpointSuffix=core.windows.net
AZURE_CONTAINER_NAME=proof-attachments

# --- DOCKER / NETWORK CONFIG ---
# This is used by the frontend to reach the backend internally in Docker
BACKEND_URL=http://backend:8080
